# =============================================================================
# SES-RAG-DEMO — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python runtime
# Virtual environment directories are large and machine-specific; exclude them.
# -----------------------------------------------------------------------------
venv/
.venv/
env/
__pycache__/
# Exclude compiled Python files (.pyc / .pyo / .pyd)
*.py[cod]
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Environment variables & secrets
# Protect against accidentally committing API keys or credentials.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.secret
secrets.json
secrets.yaml

# -----------------------------------------------------------------------------
# Streamlit cache & config (generated after ui/ is implemented)
# .streamlit/secrets.toml may contain credentials; exclude it.
# Remove .streamlit/config.toml from this list if you want to share it.
# -----------------------------------------------------------------------------
.streamlit/secrets.toml
.streamlit/cache/

# -----------------------------------------------------------------------------
# Test & coverage artifacts (generated after tests/ is implemented)
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Log files (output by the logging module)
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# OS-specific files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Editor & IDE settings
# Comment out the relevant lines if you want to share project-specific settings
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# ChromaDB persistent data (embedder.py writes to ./chroma_db/)
# The vector DB index is a local build artifact; exclude it.
# -----------------------------------------------------------------------------
chroma_db/

# =============================================================================
# Claude Code
# =============================================================================
.claude/
CLAUDE.md
